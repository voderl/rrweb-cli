{
  "name": "@voderl/rrweb-cli",
  "version": "0.1.0",
  "description": "Agent-friendly CLI for parsing, listing, and diffing rrweb session recordings.",
  "bin": {
    "rrweb-cli": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "jsdom": "^29.1.1",
    "rrweb-snapshot": "^2.0.0-alpha.4"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.19.39",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
